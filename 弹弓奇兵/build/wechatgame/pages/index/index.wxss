/* index.wxss - 微信小程序兼容版本 */
.container {
  width: 100%;
  height: 100%;
  position: relative;
  background: #667eea;
  background: -webkit-linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.game-canvas {
  width: 100%;
  height: 100%;
  display: block;
}

.loading {
  position: absolute;
  top: 50%;
  left: 50%;
  -webkit-transform: translate(-50%, -50%);
  transform: translate(-50%, -50%);
  text-align: center;
  background: rgba(0, 0, 0, 0.7);
  padding: 30px;
  border-radius: 15px;
  color: white;
  min-width: 200px;
}

.loading-text {
  font-size: 18px;
  margin-bottom: 20px;
  display: block;
}

.menu {
  position: absolute;
  top: 50%;
  left: 50%;
  -webkit-transform: translate(-50%, -50%);
  transform: translate(-50%, -50%);
  text-align: center;
  background: rgba(255, 255, 255, 0.9);
  padding: 40px;
  border-radius: 20px;
  -webkit-box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  min-width: 280px;
}

.title {
  font-size: 24px;
  font-weight: bold;
  color: #2c3e50;
  margin-bottom: 10px;
}

.subtitle {
  font-size: 16px;
  color: #7f8c8d;
  margin-bottom: 30px;
}

.start-btn, .shop-btn {
  width: 100%;
  margin: 10px 0;
  padding: 15px;
  font-size: 18px;
  border-radius: 25px;
}

.start-btn {
  background: #27ae60;
  color: white;
}

.shop-btn {
  background: #3498db;
  color: white;
}

.game-ui {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.top-bar {
  display: -webkit-flex;
  display: flex;
  -webkit-justify-content: space-between;
  justify-content: space-between;
  -webkit-align-items: center;
  align-items: center;
  padding: 15px;
  background: rgba(0, 0, 0, 0.5);
}

.gold, .score {
  color: white;
  font-size: 16px;
  font-weight: bold;
}

.pause-btn {
  background: rgba(255, 255, 255, 0.3);
  border: none;
  color: white;
  padding: 8px 15px;
  border-radius: 15px;
  pointer-events: auto;
}

.bottom-bar {
  position: absolute;
  bottom: 20px;
  left: 50%;
  -webkit-transform: translateX(-50%);
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.5);
  padding: 10px 20px;
  border-radius: 25px;
}

.heroes {
  display: -webkit-flex;
  display: flex;
  /* 移除 gap 属性，使用 margin 替代 */
}

.heroes .hero-icon {
  margin-right: 10px;
}

.heroes .hero-icon:last-child {
  margin-right: 0;
}

.hero-icon {
  width: 40px;
  height: 40px;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: -webkit-flex;
  display: flex;
  -webkit-align-items: center;
  align-items: center;
  -webkit-justify-content: center;
  justify-content: center;
  font-size: 20px;
  pointer-events: auto;
  -webkit-transition: all 0.2s;
  transition: all 0.2s;
}

.hero-icon.selected {
  background: #3498db;
  -webkit-transform: scale(1.2);
  transform: scale(1.2);
}

.result {
  position: absolute;
  top: 50%;
  left: 50%;
  -webkit-transform: translate(-50%, -50%);
  transform: translate(-50%, -50%);
  background: rgba(255, 255, 255, 0.95);
  padding: 30px;
  border-radius: 20px;
  text-align: center;
  min-width: 250px;
  -webkit-box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
}

.result-title {
  font-size: 22px;
  font-weight: bold;
  margin-bottom: 20px;
  color: #2c3e50;
}

.result-stats {
  margin-bottom: 25px;
  font-size: 16px;
  color: #7f8c8d;
}

.next-btn, .menu-btn {
  width: 100%;
  margin: 8px 0;
  padding: 12px;
  border-radius: 20px;
  font-size: 16px;
}

.next-btn {
  background: #27ae60;
  color: white;
}

.menu-btn {
  background: #95a5a6;
  color: white;
}

/* 兼容性处理 */
@media screen and (-webkit-min-device-pixel-ratio: 2) {
  .hero-icon {
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
  }
}